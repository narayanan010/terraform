#This file contains the sample credentials file to support AWSCLI MFA
#Note : After MFA code is entered once, the .json file is created under ~/.aws/cli/cache directory which has expiration after sometime. Until the expiration is reached, MFA Code won't be asked to re-enter.
#User whose keys are to be added in [cap-admin] section, must be already added to the group (that have policy sts:assumeRole allowed) from capterra-aws-admin account to the Role to be assumed in other account (crf,search,sandbox etc). If not sure, contact AWS cloud team (Colin/Sarvesh)
#Replace "mfa_serial" value with your actual mfa_serial. If not known, contact AWS cloud team (Colin/Sarvesh)
#Replace "role_arn" value with the actual role_arn you want to assume in another account (crf,search,sandbox etc)
#Keep on adding other roles you want to assume in similar chronology below.
#Usage: Eg- "aws s3 ls --profile crf-dev"
#Remove all the comments before using this file. This file is only for reference.

[cap-admin]
aws_access_key_id = xxxxxxxxxxxxxxxxxxxx
aws_secret_access_key = xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
region = us-east-1

[capterra-sandbox]
role_arn = arn:aws:iam::944xxxxx6557:role/assume-capterra-sandbox-developer-mfa
source_profile = cap-admin
region = us-east-1
mfa_serial = arn:aws:iam::237xxxx49494:mfa/username

